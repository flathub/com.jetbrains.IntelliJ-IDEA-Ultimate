{
    "id": "com.jetbrains.IntelliJ-IDEA-Ultimate",
    "runtime": "org.freedesktop.Sdk",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "idea-wrapper",
    "finish-args": [
        "--device=all",
        "--env=IDEA_PROPERTIES=/app/bin/idea.properties",
        "--env=JAVA_HOME=/app/extra/jbr",
        "--env=GROFF_FONT_PATH=/app/share/groff/current/font",
        "--env=GROFF_TMAC_PATH=/app/share/groff/current/tmac",
        "--filesystem=home",
        "--filesystem=xdg-run/app/com.discordapp.Discord:create",
        "--filesystem=xdg-run/docker",
        "--filesystem=xdg-run/gnupg",
        "--filesystem=xdg-run/keyring",
        "--filesystem=xdg-run/pipewire-0",
        "--filesystem=xdg-run/podman",
        "--share=ipc",
        "--share=network",
        "--socket=ssh-auth",
        "--socket=gpg-agent",
        "--socket=pulseaudio",
        "--socket=x11",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets"
    ],
    "modules": [
        {
            "name": "idea",
            "build-commands": [
                "install -D -t ${FLATPAK_DEST}/bin/ apply_extra idea.properties",
                "install -Dm644 -t ${FLATPAK_DEST}/share/applications/ ${FLATPAK_ID}.desktop",
                "install -Dm644 -t ${FLATPAK_DEST}/share/metainfo/ ${FLATPAK_ID}.metainfo.xml",
                "install -Dm644 -t ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/ ${FLATPAK_ID}.svg"
            ],
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "extra-data",
                    "filename": "idea.tar.gz",
                    "only-arches": [
                        "aarch64"
                    ],
                    "sha256": "77bd86b37da1536d21eba1ecbe62f5d2e23dfaf96201b24e115ab18b98737a92",
                    "size": 1515393163,
                    "url": "https://download.jetbrains.com/idea/idea-2025.3.4-aarch64.tar.gz",
                    "x-checker-data": {
                        "code": "IIU",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "extra-data",
                    "filename": "idea.tar.gz",
                    "only-arches": [
                        "x86_64"
                    ],
                    "sha256": "b86ddae3a3fd6c2afbaca160a3b7d54f4b4fa6d1361ac2616bdb7a6416632ea1",
                    "size": 1520023031,
                    "url": "https://download.jetbrains.com/idea/idea-2025.3.4.tar.gz",
                    "x-checker-data": {
                        "code": "IIU",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.IntelliJ-IDEA-Ultimate.desktop"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.IntelliJ-IDEA-Ultimate.svg"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.IntelliJ-IDEA-Ultimate.metainfo.xml"
                },
                {
                    "type": "file",
                    "path": "idea.properties"
                },
                {
                    "type": "script",
                    "dest-filename": "apply_extra",
                    "commands": [
                        "tar xzf idea.tar.gz --strip-components=1",
                        "rm idea.tar.gz"
                    ]
                }
            ]
        },
        {
            "name": "aws-cli",
            "buildsystem": "simple",
            "build-commands": [
                "./install --install-dir /app/aws-cli --bin-dir /app/bin",
                "rm -rf /app/aws-cli/v2/current/dist/awscli/examples"
            ],
            "sources": [
                {
                    "type": "archive",
                    "strip-components": 1,
                    "only-arches": [
                        "x86_64"
                    ],
                    "url": "https://awscli.amazonaws.com/awscli-exe-linux-x86_64-2.33.9.zip",
                    "sha256": "fdf377b9c5bf0caeb25965276d92c86728e395003b857cc92a61dd936f35cec2"
                },
                {
                    "type": "archive",
                    "strip-components": 1,
                    "only-arches": [
                        "aarch64"
                    ],
                    "url": "https://awscli.amazonaws.com/awscli-exe-linux-aarch64-2.33.9.zip",
                    "sha256": "b221f11a860e2724710cf2f2eb6ca47bac02d71d6fbd5558bb2b61a4ac7f3ecb"
                }
            ]
        },
        {
            "name": "ide-flatpak-wrapper",
            "buildsystem": "meson",
            "config-opts": [
                "-Deditor_binary=/app/extra/bin/idea",
                "-Deditor_title=IntelliJ IDEA",
                "-Dprogram_name=idea-wrapper",
                "-Dfirst_run_template=README.md",
                "-Dflagfile_prefix=flatpak-idea"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flathub/ide-flatpak-wrapper.git",
                    "commit": "d581fd9b873acbf6fb22899aa388435f6c00f61a"
                },
                {
                    "type": "file",
                    "path": "README.md"
                }
            ]
        }
    ]
}
