{
    "id": "com.jetbrains.IntelliJ-IDEA-Ultimate",
    "runtime": "org.freedesktop.Sdk",
    "runtime-version": "25.08",
    "sdk": "org.freedesktop.Sdk",
    "command": "idea-wrapper",
    "finish-args": [
        "--device=all",
        "--env=JAVA_HOME=/app/jbr",
        "--filesystem=home",
        "--filesystem=xdg-run/docker",
        "--filesystem=xdg-run/keyring",
        "--filesystem=xdg-run/podman",
        "--share=ipc",
        "--share=network",
        "--socket=ssh-auth",
        "--socket=gpg-agent",
        "--socket=pulseaudio",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--talk-name=org.freedesktop.Notifications",
        "--talk-name=org.freedesktop.secrets",
        "--talk-name=org.freedesktop.FileManager1"
    ],
    "modules": [
        {
            "name": "idea",
            "build-commands": [
                "cp -a idea-*/* ${FLATPAK_DEST}",
                "cat idea.properties >> ${FLATPAK_DEST}/bin/idea.properties",
                "install -Dm644 -t ${FLATPAK_DEST}/share/applications/ ${FLATPAK_ID}.desktop",
                "install -Dm644 -t ${FLATPAK_DEST}/share/metainfo/ ${FLATPAK_ID}.metainfo.xml",
                "install -Dm644 -t ${FLATPAK_DEST}/share/icons/hicolor/scalable/apps/ ${FLATPAK_ID}.svg"
            ],
            "buildsystem": "simple",
            "sources": [
                {
                    "type": "archive",
                    "strip-components": 0,
                    "only-arches": [
                        "aarch64"
                    ],
                    "sha256": "c235f664c35c20422c3ab28c850b86ea4ab7a05d9df9c027581a3a8c98be401b",
                    "url": "https://download.jetbrains.com/idea/idea-2026.1-aarch64.tar.gz",
                    "x-checker-data": {
                        "code": "IIU",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "archive",
                    "strip-components": 0,
                    "only-arches": [
                        "x86_64"
                    ],
                    "sha256": "f57d3dba9970c774cf377583629aea540418e677ec6365570e76dea9cb2f3f9b",
                    "url": "https://download.jetbrains.com/idea/idea-2026.1.tar.gz",
                    "x-checker-data": {
                        "code": "IIU",
                        "is-main-source": true,
                        "type": "jetbrains"
                    }
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.IntelliJ-IDEA-Ultimate.desktop"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.IntelliJ-IDEA-Ultimate.svg"
                },
                {
                    "type": "file",
                    "path": "com.jetbrains.IntelliJ-IDEA-Ultimate.metainfo.xml"
                },
                {
                    "type": "file",
                    "path": "idea.properties"
                }
            ]
        },
        {
            "name": "ide-flatpak-wrapper",
            "buildsystem": "meson",
            "config-opts": [
                "-Deditor_binary=/app/bin/idea",
                "-Deditor_title=IntelliJ IDEA",
                "-Dprogram_name=idea-wrapper",
                "-Dfirst_run_template=README.md",
                "-Dflagfile_prefix=flatpak-idea"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/flathub/ide-flatpak-wrapper.git",
                    "commit": "2881abaf9efc6e14923b8a0bb085275aaf2fbddf"
                },
                {
                    "type": "file",
                    "path": "README.md"
                }
            ]
        }
    ]
}
